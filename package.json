{
  "name": "@djabolum/doppelganger",
  "version": "0.1.1",
  "description": "A local-first continuity toolkit for user-approved context, handoffs, receipts, and bounded offline contract validation.",
  "license": "Apache-2.0",
  "author": "Djabolum",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Djabolum/Doppelganger.git"
  },
  "homepage": "https://github.com/Djabolum/Doppelganger#readme",
  "bugs": {
    "url": "https://github.com/Djabolum/Doppelganger/issues"
  },
  "keywords": [
    "ai",
    "cli",
    "context",
    "continuity",
    "handoff",
    "local-first",
    "offline",
    "receipts"
  ],
  "type": "commonjs",
  "bin": {
    "doppel": "dist/packages/cli/index.js"
  },
  "files": [
    "dist/",
    "scripts/",
    "schemas/",
    "contracts/quark/",
    "examples/",
    "docs/",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "test": "npm run build && node --test tests",
    "contract:doctor": "node scripts/quark-contract-doctor.js",
    "export:quark-contract-fixture": "node scripts/export-quark-contract-fixture.js",
    "dev": "ts-node packages/cli/index.ts",
    "doppel": "node dist/packages/cli/index.js"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
