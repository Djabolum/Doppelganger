{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doppelganger.local/schemas/trust_receipt.schema.json",
  "title": "Trust Receipt",
  "description": "A record of one past export. Receipt != permanent consent.",
  "type": "object",
  "required": ["id", "kind", "target", "scope", "cards_exported", "handoffs_exported", "raw_text_included", "created_at"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^rcpt_[0-9a-f]+$" },
    "kind": { "const": "trust_receipt" },
    "target": { "type": "string", "minLength": 1 },
    "scope": { "enum": ["minimal", "project", "handoff", "deep", "fossil_only"] },
    "cards_exported": { "type": "array", "items": { "type": "string" } },
    "handoffs_exported": { "type": "array", "items": { "type": "string" } },
    "raw_text_included": { "type": "boolean" },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
