{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doppelganger.local/schemas/card.schema.json",
  "title": "Card",
  "description": "A generic local note: a preference, a boundary, a project fact, or a fossil signal. Memory card != truth.",
  "type": "object",
  "required": [
    "id",
    "kind",
    "label",
    "sensitivity",
    "deep_allowed",
    "authority",
    "revocable",
    "created_at",
    "updated_at"
  ],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^(mem|bnd|prj|fos)_[0-9a-f]+$" },
    "kind": { "enum": ["memory_card", "boundary_card", "project_card", "fossil_trace"] },
    "label": { "type": "string", "minLength": 1 },
    "content": { "type": "string" },
    "sensitivity": { "enum": ["public", "normal", "sensitive"] },
    "deep_allowed": { "type": "boolean" },
    "authority": { "const": false },
    "revocable": { "const": true },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  }
}
