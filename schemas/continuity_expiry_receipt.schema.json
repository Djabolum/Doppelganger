{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doppelganger.local/schemas/continuity_expiry_receipt.schema.json",
  "title": "Continuity Expiry Receipt",
  "type": "object",
  "required": [
    "kind",
    "deposit_id",
    "state",
    "content_expired_at",
    "content_hash",
    "projection_retained",
    "tombstone_retained",
    "backup_projection_max_retention_days",
    "backup_projection_expires_no_later_than"
  ],
  "additionalProperties": false,
  "properties": {
    "kind": { "const": "continuity_expiry_receipt" },
    "deposit_id": { "type": "string", "pattern": "^qdep_[0-9a-f]+$" },
    "state": { "const": "expired" },
    "content_expired_at": { "type": "string", "format": "date-time" },
    "content_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "projection_retained": { "const": false },
    "tombstone_retained": { "const": true },
    "backup_projection_max_retention_days": { "const": 30 },
    "backup_projection_expires_no_later_than": {
      "type": "string",
      "format": "date-time"
    }
  }
}
