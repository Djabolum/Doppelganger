{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doppelganger.local/schemas/context_pack.schema.json",
  "title": "Context Pack",
  "description": "The readable output handed to an AI assistant. Context pack != identity.",
  "type": "object",
  "required": ["schema_version", "kind", "scope", "target", "generated_at", "sections", "policy"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "0.1" },
    "kind": { "const": "context_pack" },
    "scope": { "enum": ["minimal", "project", "handoff", "deep", "fossil_only"] },
    "target": { "type": "string", "minLength": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "sections": {
      "type": "object",
      "required": ["preferences", "project_context", "boundaries"],
      "additionalProperties": false,
      "properties": {
        "preferences": { "type": "array", "items": { "$ref": "card.schema.json" } },
        "project_context": { "type": "array", "items": { "$ref": "card.schema.json" } },
        "boundaries": { "type": "array", "items": { "$ref": "card.schema.json" } }
      }
    },
    "policy": {
      "type": "object",
      "required": ["authority", "memory_write_allowed", "activation_allowed", "raw_text_included"],
      "additionalProperties": false,
      "properties": {
        "authority": { "const": false },
        "memory_write_allowed": { "const": false },
        "activation_allowed": { "const": false },
        "raw_text_included": { "type": "boolean" }
      }
    }
  }
}
