{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://doppelganger.local/schemas/manifest.schema.json",
  "title": "Manifest",
  "description": "Identity anchor and metadata for a single local vault. Created once by `doppel init`.",
  "type": "object",
  "required": ["schema_version", "kind", "identity", "created_at", "vault_version"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "0.1" },
    "kind": { "const": "manifest" },
    "identity": {
      "type": "object",
      "required": ["kind", "pseudonymous_id", "authority", "created_at"],
      "additionalProperties": false,
      "properties": {
        "kind": { "enum": ["local", "email_hash", "passkey_hash"] },
        "pseudonymous_id": { "type": "string", "minLength": 1 },
        "authority": { "const": false },
        "created_at": { "type": "string", "format": "date-time" }
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "vault_version": { "const": "v0_local_file_storage" }
  }
}
